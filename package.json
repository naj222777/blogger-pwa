{
  "name": "blogger-pwa",
  "version": "0.0.1",
  "private": true,
  "description": "Build a PWA for your Blogger Site",
  "license": "MIT",
  "author": {
    "name": "Deo Kumar",
    "url": "https://github.com/kumardeo"
  },
  "homepage": "https://github.com/kumardeo/blogger-pwa",
  "repository": {
    "type": "git",
    "url": "https://github.com/kumardeo/blogger-pwa"
  },
  "bugs": {
    "url": "https://github.com/kumardeo/blogger-pwa/issues"
  },
  "packageManager": "pnpm@11.1.1",
  "type": "module",
  "scripts": {
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:types": "tsc --noEmit",
    "generate": "tsx ./src/generate.ts",
    "deploy": "pnpm run generate && wrangler deploy",
    "preview": "pnpm run generate && wrangler dev",
    "upgrade": "pnpm dlx npm-check-updates --peer --interactive --format group"
  },
  "dependencies": {
    "@deox/utils": "^0.0.5",
    "arg": "^5.0.2",
    "console-log-colors": "^0.5.0",
    "deepmerge": "^4.3.1",
    "favicons": "^7.2.0",
    "tsdown": "^0.22.0",
    "workbox-build": "^7.4.1",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.90.1"
  }
}
